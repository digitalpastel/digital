    <!-- Activation Logic & Screen Controller -->
    <script>
        // Screen Routing
        function showScreen(screenId) {
            document.getElementById('activationScreen').classList.add('hidden');
            document.getElementById('homeScreen').classList.add('hidden');
            document.getElementById('playZone').classList.add('hidden');
            
            if (screenId === 'activationScreen') {
                document.getElementById('activationScreen').classList.remove('hidden');
                document.querySelector('header').classList.add('hidden');
            } else if (screenId === 'homeScreen') {
                document.getElementById('homeScreen').classList.remove('hidden');
                document.querySelector('header').classList.remove('hidden');
            } else if (screenId === 'playZone') {
                document.getElementById('playZone').classList.remove('hidden');
                document.querySelector('header').classList.remove('hidden');
            }
        }

        // Custom child-friendly non-blocking toast warning
        function showToastBanner(text, type = "green") {
            // Remove existing duplicate toasts first to avoid layout stacking
            const existing = document.querySelectorAll('.toast-banner');
            existing.forEach(e => e.remove());

            const bgClass = type === "green" ? "bg-emerald-500" : "bg-rose-500";
            const icon = type === "green" ? "🌟" : "💡";
            const banner = document.createElement('div');
            banner.className = `toast-banner fixed top-10 left-1/2 transform -translate-x-1/2 ${bgClass} text-white font-extrabold px-6 py-3 rounded-2xl text-base md:text-xl shadow-2xl z-[9999] flex items-center space-x-2 animate-bounce border-4 border-white text-center w-[90%] max-w-md justify-center`;
            banner.innerHTML = `<span>${icon}</span> <span>${text}</span>`;
            document.body.appendChild(banner);

            setTimeout(() => {
                banner.remove();
            }, 3000);
        }

        // Device Lock Verification (Strict RULE 1, 2, 3 implementation)
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';
        let db = null;
        let auth = null;
        let firebaseReady = false;

        async function setupFirebase() {
            if (typeof __firebase_config !== 'undefined' && __firebase_config) {
                try {
                    const firebaseConfig = JSON.parse(__firebase_config);
                    const app = firebase.initializeApp(firebaseConfig);
                    auth = firebase.auth();
                    db = firebase.firestore();
                    
                    // RULE 3: Authenticate before doing queries
                    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                        await auth.signInWithCustomToken(__initial_auth_token);
                    } else {
                        await auth.signInAnonymously();
                    }
                    firebaseReady = true;
                    console.log("Firebase initialized successfully inside safe sandbox.");
                } catch (err) {
                    console.warn("Firebase config is present but connection failed. Local activation fallback enabled.", err);
                }
            } else {
                console.warn("No firebase config found. Running app in standalone sandbox mode.");
            }
        }

        // Fungsi menyemak kod pembelian (BIJAK001 hingga BIJAK100, termasuk kod sembunyi BIJAK2026)
        function checkValidPurchaseCode(code) {
            if (code === "BIJAK2026") return true; 
            const match = code.match(/^BIJAK(0\d{2}|100)$/);
            if (match) {
                const num = parseInt(match[1], 10);
                return num >= 1 && num <= 100;
            }
            return false;
        }

        async function activateApp() {
            playSound('click');
            const codeInput = document.getElementById('inputCode').value.trim().toUpperCase();
            const childNameInput = document.getElementById('inputChildName').value.trim();

            if (!codeInput || !childNameInput) {
                showToastBanner("Sila masukkan Kod Pembelian dan Nama Anak!", "rose");
                return;
            }

            if (!checkValidPurchaseCode(codeInput)) {
                showToastBanner("Kod Pembelian tidak sah! Sila guna format BIJAK____", "rose");
                return;
            }

            // Lock UI to prevent duplicate triggers
            const btn = document.getElementById('btnActivate');
            const originalContent = btn.innerHTML;
            btn.innerHTML = `<i class="fas fa-spinner animate-spin text-xl mr-2"></i> <span>Mengesahkan Kod Peranti...</span>`;
            btn.disabled = true;

            try {
                // Ensure unique device signature remains permanent inside local device storage
                let deviceId = localStorage.getItem('bj_device_id');
                if (!deviceId) {
                    deviceId = 'dev_' + Math.random().toString(36).substring(2, 15) + Date.now().toString(36);
                    localStorage.setItem('bj_device_id', deviceId);
                }

                if (firebaseReady && db) {
                    // RULE 1: Strictly follow /artifacts/{appId}/public/data/{collectionName}/{documentId} path constraints
                    const docRef = db.collection('artifacts').doc(appId).collection('public').doc('data').collection('activations').doc(codeInput);
                    
                    // RULE 2: Direct document lookup, avoiding complex querying architectures
                    const docSnap = await docRef.get();

                    if (docSnap.exists) {
                        const registeredData = docSnap.data();
                        
                        // Prevent secondary devices from using this specific bought code
                        if (registeredData.deviceId !== deviceId) {
                            showToastBanner("Kod pendaftaran ini sudah digunakan pada peranti lain!", "rose");
                            btn.innerHTML = originalContent;
                            btn.disabled = false;
                            return;
                        } else {
                            // Same device login - seamlessly update children's credentials
                            await docRef.update({
                                childName: childNameInput,
                                lastLoginAt: firebase.firestore.FieldValue.serverTimestamp()
                            });
                        }
                    } else {
                        // First registration globally of code
                        await docRef.set({
                            deviceId: deviceId,
                            childName: childNameInput,
                            purchaseCode: codeInput,
                            activatedAt: firebase.firestore.FieldValue.serverTimestamp(),
                            lastLoginAt: firebase.firestore.FieldValue.serverTimestamp()
                        });
                    }
                }

                // Register successfully locally
                localStorage.setItem('bj_activated', 'true');
                localStorage.setItem('bj_child_name', childNameInput);
                localStorage.setItem('bj_purchase_code', codeInput);

                // Celebrate Success
                playSound('win');
                confetti({
                    particleCount: 120,
                    spread: 80,
                    origin: { y: 0.6 }
                });

                showToastBanner(`Selamat Datang, ${childNameInput}! 🚀`, "green");
                
                setTimeout(() => {
                    document.getElementById('robiWelcome').innerHTML = `"Selamat Datang, ${childNameInput}! Saya Robi si Arnab!"`;
                    showScreen('homeScreen');
                }, 1800);

            } catch (err) {
                console.error("Authentication/activation lock issue: ", err);
                showToastBanner("Ralat sambungan rangkaian! Sila cuba seketika lagi.", "rose");
            } finally {
                btn.innerHTML = originalContent;
                btn.disabled = false;
            }
        }

        // Custom Secure Confirm Logout dialog avoiding native alert blocks
        function deactivateApp() {
            playSound('click');
            
            const overlay = document.createElement('div');
            overlay.className = "fixed inset-0 bg-black/50 backdrop-blur-sm z-[10000] flex items-center justify-center p-4";
            overlay.innerHTML = `
                <div class="bg-white rounded-3xl border-8 border-yellow-400 p-6 max-w-sm w-full text-center space-y-4 shadow-2xl relative overflow-hidden animate-bounce" style="animation-iteration-count: 1;">
                    <span class="text-5xl">🚪</span>
                    <h3 class="text-2xl font-black text-slate-800">Tukar Peranti / Log Keluar?</h3>
                    <p class="text-slate-600 font-medium text-sm">Adakah anda pasti mahu log keluar? Kod pembelian akan dibebaskan untuk pendaftaran baharu.</p>
                    <div class="flex space-x-3 pt-2">
                        <button id="btnCancelLogout" class="w-1/2 bg-slate-200 hover:bg-slate-300 text-slate-700 font-extrabold py-3 rounded-xl transition">Batal</button>
                        <button id="btnConfirmLogout" class="w-1/2 bg-rose-500 hover:bg-rose-600 text-white font-extrabold py-3 rounded-xl shadow-md transition flex items-center justify-center space-x-1">
                            <span>Keluar</span>
                        </button>
                    </div>
                </div>
            `;
            document.body.appendChild(overlay);

            overlay.querySelector('#btnCancelLogout').addEventListener('click', () => {
                playSound('click');
                overlay.remove();
            });

            overlay.querySelector('#btnConfirmLogout').addEventListener('click', async () => {
                playSound('click');
                const btn = overlay.querySelector('#btnConfirmLogout');
                btn.disabled = true;
                btn.innerHTML = `<i class="fas fa-spinner animate-spin mr-1"></i> <span>Memproses...</span>`;

                const purchaseCode = localStorage.getItem('bj_purchase_code');

                try {
                    // Membebaskan kunci peranti di Cloud Firestore agar kod boleh didaftar semula
                    if (firebaseReady && db && purchaseCode) {
                        const docRef = db.collection('artifacts').doc(appId).collection('public').doc('data').collection('activations').doc(purchaseCode);
                        await docRef.delete();
                        console.log("Device lock released successfully from database.");
                    }
                } catch (err) {
                    console.error("Gagal memadamkan kunci kod di pangkalan data:", err);
                }

                // Erase local state details but persist unique device ID
                localStorage.removeItem('bj_activated');
                localStorage.removeItem('bj_child_name');
                localStorage.removeItem('bj_purchase_code');
                overlay.remove();
                
                // Clear inputs inside form
                document.getElementById('inputCode').value = "";
                document.getElementById('inputChildName').value = "";
                
                showScreen('activationScreen');
                showToastBanner("Log keluar berjaya. Kod boleh digunakan semula!", "green");
            });
        }

        // Initialize App on Window Loaded
        window.onload = async function() {
            // Warmup Speech Synth
            if ('speechSynthesis' in window) {
                window.speechSynthesis.getVoices();
            }

            // Load or create persistent hardware lock
            let deviceId = localStorage.getItem('bj_device_id');
            if (!deviceId) {
                deviceId = 'dev_' + Math.random().toString(36).substring(2, 15) + Date.now().toString(36);
                localStorage.setItem('bj_device_id', deviceId);
            }

            // Establish secure connection to database
            await setupFirebase();

            // Reroute based on registration state
            const isActivated = localStorage.getItem('bj_activated');
            if (isActivated === 'true') {
                const name = localStorage.getItem('bj_child_name') || 'Kawan';
                document.getElementById('robiWelcome').innerHTML = `"Selamat Datang, ${name}! Saya Robi si Arnab!"`;
                showScreen('homeScreen');
            } else {
                showScreen('activationScreen');
            }

            console.log("Bijak Kidz Malaysia Preschool app initialized successfully with Robi si Arnab.");
        }
    </script>
</body>
</html>
